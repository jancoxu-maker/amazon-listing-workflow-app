IMAGE_API_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_PLANNER_TIMEOUT_MS=60000
GEMINI_REVIEW_TIMEOUT_MS=45000
GEMINI_IMAGE_TIMEOUT_MS=120000
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
API_PORT=5174
PUBLIC_BASE_URL=http://localhost:5174
CORS_ORIGIN=http://localhost:5173
GENERATED_IMAGE_DIR=generated-images
EXPORT_DIR=exports
ASSET_STORAGE_DIR=data/assets
# Use cloudinary, s3, or auto. Auto prefers S3 when both providers are configured.
ASSET_STORAGE_PROVIDER=auto
# Cloudinary is the recommended beta storage provider.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_DELIVERY_TYPE=authenticated
# Fill all S3-compatible object-storage values to use that provider instead.
# Compatible with Cloudflare R2, AWS S3, Backblaze B2 and other S3-compatible services.
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_SIGNED_URL_TTL_SECONDS=21600
REQUIRE_DURABLE_ASSET_STORAGE=false
MAX_UPLOADED_ASSET_BYTES=15728640
GENERATION_DAILY_USER_LIMIT=60
# 内测成本估算使用；请按当前模型价格维护，实际账单以模型服务商为准。
GENERATION_ESTIMATED_IMAGE_COST_USD=0.04
VITE_IMAGE_API_BASE_URL=http://localhost:5174
DATABASE_URL=
DATABASE_SSL=false
DATABASE_POOL_SIZE=6
DATABASE_CONNECT_TIMEOUT_MS=8000
DATABASE_QUERY_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_RETRY_ATTEMPTS=3
DATABASE_RETRY_BASE_MS=500
DATABASE_RETRY_MAX_MS=5000
GENERATION_WORKER_RETRY_BASE_MS=5000
GENERATION_WORKER_RETRY_MAX_MS=300000
AUTH_SESSION_DAYS=14
